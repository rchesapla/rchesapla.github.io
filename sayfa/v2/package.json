{
  "name": "roller-coin-calculator",
  "version": "1.0.1",
  "description": "Electron calculator for RollerCoin miner choice v1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "release:win": "electron-builder --win nsis --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rollercoin.calculator",
    "productName": "RollerCoin Calculator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "FullMetaaal",
        "repo": "Rollercoint_calculator",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
