{
  "name": "roller-coin-calculator",
  "version": "1.0.2",
  "private": true,
  "description": "Electron calculator for RollerCoin miner choice v1",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:renderer && node scripts/start-electron.cjs",
    "build:renderer": "vite build",
    "preview:renderer": "vite preview --host 127.0.0.1 --strictPort",
    "build": "npm run build:renderer && electron-builder",
    "dist:win": "npm run build:renderer && electron-builder --win nsis",
    "release:win": "npm run build:renderer && electron-builder --win nsis --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^25.1.8",
    "vite": "^7.1.7"
  },
  "build": {
    "appId": "com.rollercoin.calculator",
    "productName": "RollerCoin Calculator",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "dist/renderer/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "FullMetaaal",
        "repo": "Rollercoint_calculator",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
